# Copiá este archivo a server/.env y completá los valores.
# (server/.env está en .gitignore — los secretos NO van al repo.)

# Credenciales de la herramienta interna (Basic Auth, igual patrón que el videodownloader).
# Si APP_USER queda VACÍO, la auth se DESHABILITA → solo para dev local.
APP_USER=admin
APP_PASSWORD=cambiar-esta-clave

# Puerto local del backend. Caddy hace reverse_proxy a este puerto.
PORT=8090

# Días de retención. 21 = pedido del equipo. El reloj corre DESDE LA CARGA del audio.
RETENTION_DAYS=21

# Transcripción automática (al subir varios audios). Primario AssemblyAI, fallback OpenAI Whisper.
# Con al menos una alcanza; con las dos, si AssemblyAI falla usa Whisper.
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=

# Base pública para construir las URLs de reporte.
#   Prod: https://comlog.cienradios.com
#   Local: dejar vacío → se deriva del request (http://localhost:8090).
PUBLIC_BASE_URL=

# ── Cargar desde el aire (logger HDX vía bridge de cronograma) ──
# HDX vive en la red corp; comercial le llega a través de los endpoints que expone
# cronograma (/api/hdx/logger*). Sin estas vars, la opción "Desde el aire" queda inactiva.
#   Prod:  https://cronograma.cienradios.com
#   Local: http://localhost:3001 (cronograma corriendo local, con túnel HDX arriba)
LOGGER_BRIDGE_URL=
# Secreto compartido con cronograma (debe coincidir con LOGGER_BRIDGE_TOKEN allá).
LOGGER_BRIDGE_TOKEN=
# Creds de la basic-auth de nginx de cronograma, "user:pass" (opcional).
# Si cronograma deja pasar /api/hdx/logger* sin basic-auth, dejar vacío.
LOGGER_BRIDGE_BASIC=
# Guarda dura de duración total del audio bajado (segundos). Default 25200 = 7 h.
LOGGER_MAX_AUDIO_SEC=
