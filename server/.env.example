# Copiá este archivo a server/.env y completá los valores.
# (server/.env está en .gitignore — los secretos NO van al repo.)

# Credenciales de la herramienta interna (Basic Auth, igual patrón que el videodownloader).
# Si APP_USER queda VACÍO, la auth se DESHABILITA → solo para dev local.
APP_USER=admin
APP_PASSWORD=cambiar-esta-clave

# Puerto local del backend. Caddy hace reverse_proxy a este puerto.
PORT=8090

# Días de retención. 21 = pedido del equipo. El reloj corre DESDE LA CARGA del audio.
RETENTION_DAYS=21

# Base pública para construir las URLs de reporte.
#   Prod: https://comlog.cienradios.com
#   Local: dejar vacío → se deriva del request (http://localhost:8090).
PUBLIC_BASE_URL=
